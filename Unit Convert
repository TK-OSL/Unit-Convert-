            const inactiveFromSIClass = "w-full py-4 px-4 rounded-xl font-bold text-base sm:text-lg flex items-center justify-center transition-all duration-300 bg-transparent text-slate-500 hover:bg-white hover:text-slate-800 hover:shadow-sm";

            if(mode === 'to-si') {
                btnToSI.className = activeToSIClass;
                btnFromSI.className = inactiveFromSIClass;
                convertBtn.className = "mt-6 w-full font-bold py-4 px-4 rounded-xl flex items-center justify-center space-x-2 transition-colors duration-200 text-white shadow-md bg-blue-600 hover:bg-blue-700 text-lg";
            } else {
                btnToSI.className = inactiveToSIClass;
                btnFromSI.className = activeFromSIClass;
                convertBtn.className = "mt-6 w-full font-bold py-4 px-4 rounded-xl flex items-center justify-center space-x-2 transition-colors duration-200 text-white shadow-md bg-emerald-600 hover:bg-emerald-700 text-lg";
            }
            
            resetResult();
            updateUI();
        }

        // Update UI Text & Select Options dynamically based on state
        function updateUI() {
            const data = unitData[currentCategory];
            const isReverse = currentMode === 'from-si';
            const trans = uiTranslations[currentLang];

            // Update Info Box
            document.getElementById('si-info-text').innerText = data.info[currentLang];
            document.getElementById('si-info-symbol').innerText = data.siUnit[currentLang];

            // Update Labels
            document.getElementById('form-title').innerText = isReverse ? trans["dyn-form-title-from"] : trans["dyn-form-title-to"];
            document.getElementById('input-label').innerText = isReverse ? trans["dyn-input-label-from"] : trans["dyn-input-label-to"];
            document.getElementById('select-label').innerText = isReverse ? trans["dyn-select-label-from"] : trans["dyn-select-label-to"];

            // Update Input Symbol (Show SI symbol in Mode 2)
            const inputSymbolElem = document.getElementById('input-unit-symbol');
            if (isReverse) {
                inputSymbolElem.innerText = data.siSymbol;
                inputSymbolElem.classList.remove('hidden');
            } else {
                inputSymbolElem.classList.add('hidden');
            }

            // Update Select Options (preserve selection if exists)
            const currentSelected = unitSelect.value;
            unitSelect.innerHTML = '';
            data.units.forEach(u => {
                const opt = document.createElement('option');
                opt.value = u.id;
                opt.innerText = u.name[currentLang];
                unitSelect.appendChild(opt);
            });
            if(currentSelected && Array.from(unitSelect.options).some(o => o.value === currentSelected)) {
                unitSelect.value = currentSelected;
            }
        }

        // Handle Conversion
        function handleConvert() {
            const val = parseFloat(inputValueElem.value);
            if (isNaN(val)) return;

            const isReverse = currentMode === 'from-si';
            const data = unitData[currentCategory];
            const selectedUnit = data.units.find(u => u.id === unitSelect.value);
            const trans = uiTranslations[currentLang];
            
            let calculatedResult = 0;
            let baseFormula = '';

            // Math Logic
            if (!isReverse) {
                if (selectedUnit.isTemp) {
                    calculatedResult = selectedUnit.toSI(val);
                    baseFormula = selectedUnit.formula;
                } else {
                    calculatedResult = val * selectedUnit.factor;
                    baseFormula = selectedUnit.formula;
                }
            } else {
                if (selectedUnit.isTemp) {
                    calculatedResult = selectedUnit.fromSI(val);
                    baseFormula = selectedUnit.revFormula;
                } else {
                    calculatedResult = val / selectedUnit.factor;
                    baseFormula = selectedUnit.formula.includes('*') 
                        ? selectedUnit.formula.replace('*', '/')
                        : selectedUnit.formula.replace('/', '*');
                }
            }

            let stepFormula = baseFormula.replace(/x/g, val);

            // Format formatting
            let formattedResult;
            if (calculatedResult === 0) {
                formattedResult = 0;
            } else if (Math.abs(calculatedResult) < 0.0001 || Math.abs(calculatedResult) >= 10000000) {
                formattedResult = calculatedResult.toExponential(4);
            } else {
                formattedResult = Number.isInteger(calculatedResult) 
                    ? calculatedResult 
                    : parseFloat(calculatedResult.toPrecision(7));
            }

            // Names for output
            // Name format from data: e.g. "Meter (m)" or "เมตร (m)". We extract the symbol in parentheses for display.
            const extractSymbol = (str) => { const match = str.match(/\((.*?)\)/); return match ? match[1] : str; };
            const unitNameText = extractSymbol(selectedUnit.name[currentLang]);
            
            const fromName = isReverse ? data.siSymbol : unitNameText;
            const toName = isReverse ? unitNameText : data.siSymbol;

            // Update Result DOM
            document.getElementById('res-input-val').innerText = val;
            document.getElementById('res-input-unit').innerText = fromName;
            document.getElementById('res-output-val').innerText = formattedResult;
            document.getElementById('res-output-unit').innerText = toName;

            // Update Steps DOM logic strings
            document.getElementById('step-factor').innerText = selectedUnit.isTemp ? trans["dyn-factor-temp"] : `${selectedUnit.factor}`;
            
            if (selectedUnit.isTemp) {
                document.getElementById('step-principle').innerText = isReverse ? trans["dyn-principle-temp-from"] : trans["dyn-principle-temp-to"];
            } else {
                document.getElementById('step-principle').innerText = isReverse ? trans["dyn-principle-div"] : trans["dyn-principle-mult"];
            }

            document.getElementById('step-formula').innerText = baseFormula.replace('x', isReverse ? trans["dyn-val-si"] : trans["dyn-val-init"]);
            document.getElementById('step-calc').innerText = stepFormula;
            document.getElementById('step-final').innerText = `${val} ${fromName} = ${formattedResult} ${toName}`;

            // Show Result Box
            resultBox.classList.remove('hidden');
        }

        // Reset Result
        function resetResult() {
            resultBox.classList.add('hidden');
            inputValueElem.value = '1';
        }

        // Run setup
        initApp();

    </script>
</body>
</html>
