        // Change Language
        function setLanguage(lang) {
            currentLang = lang;
            
            // Update Toggle UI styles matching screenshot
            const btnEn = document.getElementById('lang-en');
            const btnTh = document.getElementById('lang-th');
            
            if (lang === 'en') {
                btnEn.className = "px-3 py-1.5 rounded-md font-bold text-sm transition-all duration-200 bg-white text-blue-600 shadow-sm";
                btnTh.className = "px-3 py-1.5 rounded-md font-bold text-sm transition-all duration-200 text-slate-500 hover:text-orange-500";
            } else {
                btnEn.className = "px-3 py-1.5 rounded-md font-bold text-sm transition-all duration-200 text-slate-500 hover:text-blue-600";
                btnTh.className = "px-3 py-1.5 rounded-md font-bold text-sm transition-all duration-200 bg-white text-orange-500 shadow-sm";
            }

            // Update Static Texts
            const translations = uiTranslations[lang];
            Object.keys(translations).forEach(key => {
                const element = document.getElementById(key);
                if (element && !key.startsWith('dyn-')) {
                    element.innerHTML = translations[key];
                }
            });

            // Re-render components with new language
            renderCategories();
            updateUI();
            
            // If result is shown, trigger recalculate to update output languages
            if (!resultBox.classList.contains('hidden')) {
                handleConvert();
            }
        }

        // Render Categories
        function renderCategories() {
            categoryList.innerHTML = '';
            Object.entries(unitData).forEach(([key, data]) => {
                const btn = document.createElement('button');
                btn.className = `w-full text-left px-4 py-3 rounded-lg border transition-all duration-200 ${currentCategory === key ? 'border-blue-500 bg-blue-50 text-blue-700 font-medium' : 'border-slate-200 hover:border-blue-300 hover:bg-slate-50'}`;
                btn.innerText = data.name[currentLang];
                btn.onclick = () => setCategory(key);
                categoryList.appendChild(btn);
            });
        }

        // Change Category
        function setCategory(key) {
            currentCategory = key;
            renderCategories(); // Re-render to update selected style
            resetResult();
            updateUI();
        }

